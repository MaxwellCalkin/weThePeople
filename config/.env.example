PORT=3000

# MongoDB Atlas connection string
DB_STRING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Cloudinary (image uploads) — https://cloudinary.com/console
CLOUD_NAME=
API_KEY=
API_SECRET=

# Congress.gov API key (free) — sign up at https://api.data.gov/signup/
CONGRESS_KEY=

# Google Civic Information API key — https://console.cloud.google.com/apis
GOOGLE_KEY=
