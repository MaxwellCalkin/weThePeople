<%- include('partials/headerBoot') -%>
    <div class="container">

        <div class="row mt-3">
             <% for(var i=0; i<billsArray.length && i < 18; i++) {%>
                <div class="container col-sm-12 col-md-6 col-lg-4">
                    <div class="card p-0 mb-3">
                        <div class="card-body">
                            <small class="text-muted"><%= billsArray[i].bill_id.split('-')[0].toUpperCase().replace(/^HR/, 'H.R. ').replace(/^S(\d)/, 'S. $1').replace(/^HJRES/, 'H.J.Res. ').replace(/^SJRES/, 'S.J.Res. ').replace(/^HRES/, 'H.Res. ').replace(/^SRES/, 'S.Res. ') %></small>
                            <h5 class="card-title"><%= billsArray[i].short_title ? billsArray[i].short_title : billsArray[i].title%></h5>

                            <% if(user.yeaBillSlugs.includes(billsArray[i].bill_id.split('-')[0]) || user.nayBillSlugs.includes(billsArray[i].bill_id.split('-')[0])) {%>
                                <a href="/vote/detailsVoted/<%= billsArray[i].bill_id.slice(0,billsArray[i].bill_id.indexOf('-'))%>/<%= billsArray[i].bill_id.slice(billsArray[i].bill_id.indexOf('-') + 1)%>">You Voted! View Details</a>
                            <% }else{ %>    
                                <a href="/vote/details/<%= billsArray[i].bill_id.slice(0,billsArray[i].bill_id.indexOf('-'))%>/<%= billsArray[i].bill_id.slice(billsArray[i].bill_id.indexOf('-') + 1)%>">View Details and Vote</a>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>  
<%- include('partials/footer') -%>